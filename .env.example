# App
NEXT_PUBLIC_URL=http://localhost:3000

# OpenRouter (free-tier LLM for trend analysis + script generation)
OPENROUTER_API_KEY=

# LTX-2 (video generation — https://console.ltx.video)
LTX_API_KEY=

# ─── x402 Payment Layer (Monad) ───────────────────────────────────────────────
# Treasury wallet that receives payments
TREASURY_WALLET=
# Monad Testnet (switch to eip155:143 for Mainnet)
X402_NETWORK=eip155:10143
X402_CAIP2=eip155:10143
# USDC on Monad Testnet (6 decimals)
X402_ASSET=0x534b2f3A21130d7a60830c2Df862319e593943A3
X402_ASSET_NAME=USDC
X402_ASSET_VERSION=2
X402_ASSET_TRANSFER_METHOD=eip3009
# Monad x402 facilitator
X402_FACILITATOR_URL=https://x402-facilitator.molandak.org

# ─── ERC-8004 Agent Identity (Monad) ─────────────────────────────────────────
# Private key for the wallet that owns the agent NFT (needs MON for gas)
# Get testnet MON: https://faucet.monad.xyz
AGENT_PRIVATE_KEY=

# Set AFTER running: node scripts/register-agent.mjs
ERC8004_AGENT_ID=
ERC8004_AGENT_URI=
# Monad Testnet registry (switch to 0x8004A169FB4a3325136EB29fA0ceB6D2e539a432 for Mainnet)
ERC8004_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_NETWORK=eip155:10143

# ─── Pinata IPFS (required for ERC-8004 registration) ────────────────────────
# Sign up free at https://pinata.cloud
# API Keys → New Key → copy the JWT token
PINATA_JWT=
# Gateways → your dedicated gateway domain (e.g. rose-abc.mypinata.cloud)
PINATA_GATEWAY=

# State storage (file adapter by default)
MONADFLUENCE_STATE_ADAPTER=file
# On Vercel set this to /tmp/monadfluence-state.json (or use a persistent DB/KV).
MONADFLUENCE_STATE_FILE=.data/monadfluence-state.json

# Optional media persistence (recommended; PiAPI output URLs can be short-lived)
# Option A: your own persistence service endpoint returning JSON: { "url": "https://..." }
MONADFLUENCE_ASSET_PERSIST_ENDPOINT=
# Option B: Vercel Blob (if set, completed images/videos are copied to Blob storage)
BLOB_READ_WRITE_TOKEN=

# Caption service (VPS with FFmpeg — burns word-by-word captions into videos)
CAPTION_SERVICE_URL=
CAPTION_SERVICE_SECRET=

# Instagram publishing
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_OAUTH_URL=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_content_publish,pages_show_list,business_management
FACEBOOK_GRAPH_VERSION=v21.0
# On Vercel set this to /tmp/instagram-connection.json (or use a persistent DB/KV).
MONADFLUENCE_INSTAGRAM_STATE_FILE=.data/instagram-connection.json
