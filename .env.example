# App
NEXT_PUBLIC_URL=http://localhost:3000

# OpenRouter (free-tier LLM for trend analysis + script generation)
OPENROUTER_API_KEY=

# LTX-2 (video generation — https://console.ltx.video)
LTX_API_KEY=

# ─── x402 Payment Layer (Avalanche Fuji) ───────────────────────────────────────────────
# Treasury wallet that receives payments
TREASURY_WALLET=
# Avalanche Fuji Testnet (switch to eip155:43114 for Mainnet)
X402_NETWORK=eip155:43113
X402_CAIP2=eip155:43113
# USDC on Avalanche Fuji Testnet (6 decimals)
X402_ASSET=0x5425890298aed601595a70AB815c96711a31Bc65
X402_ASSET_NAME=USDC
X402_ASSET_VERSION=2
X402_ASSET_TRANSFER_METHOD=eip3009
# Avalanche-native x402 facilitator (Ultravioleta DAO — gasless for users)
# Alternatives: Thirdweb (portal.thirdweb.com/x402), PayAI (payai.network)
# Docs: https://build.avax.network/integrations/ultravioletadao
X402_FACILITATOR_URL=https://facilitator.ultravioletadao.xyz

# ─── ERC-8004 Agent Identity (Avalanche Fuji) ─────────────────────────────────────────
# Private key for the wallet that owns the agent NFT (needs AVAX for gas)
# Get testnet AVAX: https://faucet.avax.network
AGENT_PRIVATE_KEY=

# Set AFTER running: node scripts/register-agent.mjs
ERC8004_AGENT_ID=
ERC8004_AGENT_URI=
# Avalanche Fuji Testnet registry (placeholder — ERC-8004 not yet deployed on Avalanche)
ERC8004_REGISTRY=0x0000000000000000000000000000000000008004
ERC8004_NETWORK=eip155:43113

# ─── Pinata IPFS (required for ERC-8004 registration) ────────────────────────
# Sign up free at https://pinata.cloud
# API Keys → New Key → copy the JWT token
PINATA_JWT=
# Gateways → your dedicated gateway domain (e.g. rose-abc.mypinata.cloud)
PINATA_GATEWAY=

# ─── Interchain Content Attestation (Avalanche Teleporter / AWM) ──────────
# Cross-chain content provenance via Teleporter.
# After paid video generation, an attestation is sent from C-Chain to a
# ContentAttestationRegistry on a destination L1 via Avalanche Warp Messaging.
# Docs: https://build.avax.network/docs/cross-chain/teleporter/overview
# TeleporterMessenger (all chains): 0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf
# TeleporterRegistry (Fuji C-Chain): 0xF86Cb19Ad8405AEFa7d09C778215D2Cb6eBfB228
ATTESTATION_SENDER_ADDRESS=
ATTESTATION_REGISTRY_ADDRESS=
ATTESTATION_DEST_BLOCKCHAIN_ID=
ATTESTATION_DEST_RPC=

# State storage (file adapter by default)
MOLTFLUENCE_STATE_ADAPTER=file
# On Vercel set this to /tmp/moltfluence-state.json (or use a persistent DB/KV).
MOLTFLUENCE_STATE_FILE=.data/moltfluence-state.json

# Optional media persistence (recommended; PiAPI output URLs can be short-lived)
# Option A: your own persistence service endpoint returning JSON: { "url": "https://..." }
MOLTFLUENCE_ASSET_PERSIST_ENDPOINT=
# Option B: Vercel Blob (if set, completed images/videos are copied to Blob storage)
BLOB_READ_WRITE_TOKEN=

# Caption service (VPS with FFmpeg — burns word-by-word captions into videos)
CAPTION_SERVICE_URL=
CAPTION_SERVICE_SECRET=

# Instagram publishing
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_OAUTH_URL=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_content_publish,pages_show_list,business_management
FACEBOOK_GRAPH_VERSION=v21.0
# On Vercel set this to /tmp/instagram-connection.json (or use a persistent DB/KV).
MOLTFLUENCE_INSTAGRAM_STATE_FILE=.data/instagram-connection.json
